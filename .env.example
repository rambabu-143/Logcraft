# Database (Supabase PostgreSQL)
DATABASE_URL="postgresql://postgres:[password]@[host]:5432/postgres"

# NextAuth
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"
NEXTAUTH_URL="http://localhost:3000"

# GitHub OAuth App (github.com/settings/applications/new)
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# GitHub Webhook Secret (any random string)
GITHUB_WEBHOOK_SECRET="generate-with: openssl rand -hex 20"

# ZhipuAI / Z AI (open.bigmodel.cn)
ZHIPUAI_API_KEY=""

# Stripe (dashboard.stripe.com)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_STARTER_PRICE_ID=""
STRIPE_PRO_PRICE_ID=""

# Resend (resend.com/api-keys)
RESEND_API_KEY=""
RESEND_FROM_EMAIL="changelogs@changelogfy.com"
